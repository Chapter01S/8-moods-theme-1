    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 70
    }
  ],
  "presets": [
    {
      "name": "Shipping & returns"
    }
  ]
}
{% endschema %}
