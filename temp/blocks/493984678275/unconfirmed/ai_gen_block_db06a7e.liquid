{% doc %}
  @prompt
    Create a contact form with a custom tex option above and the form should include name email adress and comment. make sure its customasiable
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__custom-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.custom_text_size }}px;
    line-height: 1.5;
    margin-bottom: {{ block.settings.custom_text_spacing }}px;
  }

  .ai-contact-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    font-size: {{ block.settings.input_text_size }}px;
    font-family: inherit;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: {{ block.settings.textarea_height }}px;
    resize: vertical;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    cursor: pointer;
    transition: background-color 0.3s ease;
    width: 100%;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.success_background_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
    text-align: center;
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.error_background_color }};
    color: {{ block.settings.error_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.form_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-form__header-{{ ai_gen_id }}">
    {% if block.settings.custom_text != blank %}
      <div class="ai-contact-form__custom-text-{{ ai_gen_id }}">
        {{ block.settings.custom_text }}
      </div>
    {% endif %}
  </div>

  {%- form 'contact' -%}
    <div class="ai-contact-form__form-{{ ai_gen_id }}">
      {%- if form.posted_successfully? -%}
        <div class="ai-contact-form__success-{{ ai_gen_id }}" id="ai-contact-form-success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="ai-contact-form__error-{{ ai_gen_id }}" id="ai-contact-form-error-{{ ai_gen_id }}">
          <h3>{{ block.settings.error_heading }}</h3>
          <ul>
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  {{ form.errors.messages[field] }}
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {% if block.settings.show_name_field %}
        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label class="ai-contact-form__label-{{ ai_gen_id }}" for="ai-contact-name-{{ ai_gen_id }}">
            {{ block.settings.name_label }}{% if block.settings.name_required %}*{% endif %}
          </label>
          <input
            type="text"
            id="ai-contact-name-{{ ai_gen_id }}"
            name="contact[{{ block.settings.name_field_name }}]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.name_placeholder }}"
            {% if block.settings.name_required %}required{% endif %}
            {% if form.errors %}
              {% if form.errors contains block.settings.name_field_name %}
                aria-invalid="true"
                aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
              {% endif %}
            {% endif %}
          >
        </div>
      {% endif %}

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-contact-form__label-{{ ai_gen_id }}" for="ai-contact-email-{{ ai_gen_id }}">
          {{ block.settings.email_label }}*
        </label>
        <input
          type="email"
          id="ai-contact-email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.email_placeholder }}"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          required
          {% if form.errors %}
            {% if form.errors contains 'email' %}
              aria-invalid="true"
              aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
            {% endif %}
          {% endif %}
        >
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-contact-form__label-{{ ai_gen_id }}" for="ai-contact-message-{{ ai_gen_id }}">
          {{ block.settings.message_label }}{% if block.settings.message_required %}*{% endif %}
        </label>
        <textarea
          id="ai-contact-message-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-contact-form__textarea-{{ ai_gen_id }}"
          placeholder="{{ block.settings.message_placeholder }}"
          {% if block.settings.message_required %}required{% endif %}
          {% if form.errors %}
            {% if form.errors contains 'body' %}
              aria-invalid="true"
              aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
            {% endif %}
          {% endif %}
        ></textarea>
      </div>

      <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
  {%- endform -%}
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        const successMessage = this.querySelector('#ai-contact-form-success-{{ ai_gen_id }}');
        const errorMessage = this.querySelector('#ai-contact-form-error-{{ ai_gen_id }}');

        if (successMessage || errorMessage) {
          const targetElement = successMessage || errorMessage;
          setTimeout(() => {
            targetElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 100);
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

